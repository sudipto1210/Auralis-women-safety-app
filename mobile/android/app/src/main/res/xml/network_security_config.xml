<?xml version="1.0" encoding="utf-8"?>
<!--
  AURALIS Network Security Configuration — RELEASE
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  Release builds enforce HTTPS-only:
    • cleartextTrafficPermitted="false" — blocks all HTTP traffic
    • Trusts ONLY system CA roots (no user-installed CAs)
      This prevents MitM attacks using self-signed or rogue CAs
      installed on the device by the user or attacker.

  Debug builds use a separate override in:
    android/app/src/debug/res/xml/network_security_config.xml
  which re-enables cleartext HTTP for local dev servers (10.0.2.2 / LAN).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust system CA store only — reject user-installed CA certs -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
