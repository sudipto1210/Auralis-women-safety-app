<?xml version="1.0" encoding="utf-8"?>
<!--
  AURALIS Network Security Configuration — DEBUG OVERRIDE
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  This file is placed in the debug source set (src/debug/) so it
  ONLY applies to debug builds (./gradlew assembleDebug). It is
  completely absent from release builds.

  Relaxations vs the release config:
    • cleartextTrafficPermitted="true" — allows HTTP for local dev servers
      running on 10.0.2.2 (Android emulator host alias) or LAN IPs.
    • user-certificates trusted — allows Charles / mitmproxy for debugging.

  WARNING: This file must NEVER be merged into src/main/.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust system CAs -->
            <certificates src="system" />
            <!-- Trust user-installed CAs in debug (allows proxy tools) -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
