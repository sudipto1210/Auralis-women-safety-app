<?xml version="1.0" encoding="utf-8"?>
<!--
  AURALIS Network Security Configuration — DEBUG OVERRIDE
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  This file is placed in src/debug/ and overrides the release
  config ONLY in debug builds (merged by the Android build system).

  Allows cleartext traffic to:
    • 10.0.2.2 — Android emulator host (maps to your laptop's localhost)
    • 10.0.0.0/8, 192.168.0.0/16, 172.16.0.0/12 — LAN development

  Trusts user-installed CAs (for proxy tools like Charles/Proxyman in dev).
  DO NOT ship this config in a release build.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <!-- Trust user CAs only in debug for local proxy inspection -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Emulator host — React Native Metro bundler and Flask backend -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- LAN development (physical device pointed at dev laptop) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.0</domain>
        <domain includeSubdomains="false">192.168.0.0</domain>
    </domain-config>
</network-security-config>
